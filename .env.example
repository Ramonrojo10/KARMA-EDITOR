# ==============================================
# KARMA OPS EDITOR - Environment Configuration
# ==============================================
# Copy this file to .env and fill in the values

# ==============================================
# DATABASE
# ==============================================
# PostgreSQL connection string
# Format: postgres://username:password@host:port/database
# NOTE: SSL is DISABLED in this application (database doesn't support it)
DATABASE_URL=postgres://postgres:your-password@localhost:5432/karma_editing

# For Docker/Coolify internal network, use the container name as host:
# DATABASE_URL=postgres://postgres:your-password@postgres-container:5432/karma_editing

# ==============================================
# AUTHENTICATION
# ==============================================
# JWT Secret - CHANGE THIS IN PRODUCTION!
# Generate a secure random string (min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ==============================================
# N8N WEBHOOK
# ==============================================
# URL to trigger n8n workflow when video is uploaded
N8N_WEBHOOK_URL=https://n8n2.0.karmaops.online/webhook/video-upload

# ==============================================
# YOUTUBE API (Optional)
# ==============================================
# Required for YouTube Studio view
# Get your API key from: https://console.developers.google.com/
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_CHANNEL_ID=your-channel-id

# ==============================================
# SERVER
# ==============================================
# Port for the backend server
PORT=4000

# Environment: development or production
NODE_ENV=production

# Frontend URL (for CORS in production)
FRONTEND_URL=https://your-domain.com

# ==============================================
# FILE UPLOADS
# ==============================================
# Directory for temporary file uploads
UPLOAD_DIR=/tmp/uploads
